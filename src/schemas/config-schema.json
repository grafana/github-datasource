{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHubDataSourceConfig",
  "description": "Configuration schema for the Grafana GitHub data source plugin",
  "type": "object",
  "properties": {
    "jsonData": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "allOf": [
        {
          "anyOf": [
            {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "githubPlan": {
                      "type": "string",
                      "const": "github-basic"
                    },
                    "githubUrl": {
                      "not": {}
                    }
                  },
                  "required": [
                    "githubUrl"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "githubPlan": {
                      "type": "string",
                      "const": "github-enterprise-cloud"
                    },
                    "githubUrl": {
                      "not": {}
                    }
                  },
                  "required": [
                    "githubPlan",
                    "githubUrl"
                  ],
                  "additionalProperties": false
                }
              ]
            },
            {
              "type": "object",
              "properties": {
                "githubPlan": {
                  "type": "string",
                  "const": "github-enterprise-server"
                },
                "githubUrl": {
                  "type": "string"
                }
              },
              "required": [
                "githubPlan",
                "githubUrl"
              ],
              "additionalProperties": false
            }
          ]
        },
        {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "selectedAuthType": {
                  "type": "string",
                  "const": "personal-access-token"
                },
                "appId": {
                  "not": {}
                },
                "installationId": {
                  "not": {}
                }
              },
              "required": [
                "appId",
                "installationId"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "selectedAuthType": {
                  "type": "string",
                  "const": "github-app"
                },
                "appId": {
                  "type": "string"
                },
                "installationId": {
                  "type": "string"
                }
              },
              "required": [
                "selectedAuthType",
                "appId",
                "installationId"
              ],
              "additionalProperties": false
            }
          ]
        }
      ]
    },
    "secureJsonData": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "accessToken": {
              "type": "string"
            },
            "privateKey": {
              "not": {}
            }
          },
          "required": [
            "accessToken",
            "privateKey"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "accessToken": {
              "not": {}
            },
            "privateKey": {
              "type": "string"
            }
          },
          "required": [
            "accessToken",
            "privateKey"
          ],
          "additionalProperties": false
        }
      ]
    }
  }
}
